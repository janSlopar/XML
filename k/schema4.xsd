            <kolegij>XML tehnologije</kolegij>
            <status>prijavljen</status>
            <grupa>A01</grupa>
        </prijavaIspita>
    ]]>

    <xs:complexType name="prijavaIspita">

        <xs:element name="student" type="xs:string" />
        <xs:element name="kolegij" type="xs:string" />
        <xs:simpleType name="status">
            <xs:restriction base="xs:string">
                <xs:enumeration value="prijavljen" />
